# Copy to .env.local. Never commit .env.local or paste its values into URLs.

# Live = TxLINE mainnet level 12 only. Simulation is labelled separately.
TXLINE_MODE=live
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_API_TOKEN=
TXLINE_COMPETITION_ID=

# Fixture supervisor queue (France–England, then Spain–Argentina).
TXLINE_WATCH_FIXTURE_IDS=18257865,18257739
# Optional single-fixture override for local preflight / forced attach.
TXLINE_FIXTURE_ID=

# Optional activation path if no pre-minted API token is supplied.
TXLINE_HOST_SECRET_KEY=
TXLINE_TX_SIG=
TXLINE_LEAGUES=

# Required for POST mutations. Public viewers never need this.
SWEEPER_CONTROL_KEY=

# Railway / production: durable event store + auto-start supervisor.
DATABASE_URL=
SWEEPER_AUTO_START_LIVE=false

# Optional TxLINE historical table generated by npm run horizon:train.
HORIZON_ARTIFACT_PATH=./data/horizon-frequency.json

# Optional API-Football tempo enrichment (shots / shots on target).
# UI-only — never used for Horizon settlement. Free tier ~100 req/day.
API_FOOTBALL_KEY=
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Official mainnet settlement verification (validateStatV2).
SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Optional Solana *devnet* audit-root anchoring (never mainnet key material).
SOLANA_ANCHOR_SECRET_KEY=
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
