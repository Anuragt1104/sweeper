# Copy to .env.local. Never commit .env.local or paste its values into URLs.

# Tonight: TxLINE mainnet level 12, France vs Spain, 00:30 IST.
TXLINE_MODE=live
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_FIXTURE_ID=18237038
TXLINE_API_TOKEN=
TXLINE_COMPETITION_ID=

# Optional activation path if no pre-minted API token is supplied.
TXLINE_HOST_SECRET_KEY=
TXLINE_TX_SIG=
TXLINE_LEAGUES=

# Required for POST /api/session and POST /api/replay.
# Public viewers never need this. Operators enter it in the UI; it stays in sessionStorage.
SWEEPER_CONTROL_KEY=

# Optional TxLINE historical table generated by npm run horizon:train.
HORIZON_ARTIFACT_PATH=./data/horizon-frequency.json

# Optional API-Football tempo enrichment (shots / shots on target).
# UI-only — never used for Horizon settlement. Free tier ~100 req/day.
API_FOOTBALL_KEY=
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Optional Solana devnet audit-root anchoring.
SOLANA_ANCHOR_SECRET_KEY=
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
